          "type": "string",
          "description": "Unique identifier for request correlation and tracking"
        },
        "type": {
          "type": "string",
          "const": "end_conversation",
          "description": "Message type for ending a conversation"
        },
        "sessionId": {
          "type": "string",
          "description": "Session ID containing the conversation"
        },
        "conversationId": {
          "type": "string",
          "description": "Unique identifier of the conversation to end"
