        "requestId": {
          "description": "Optional request ID for correlating responses with requests",
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "end_conversation",
          "description": "Message type for end conversation response"
        },
        "sessionId": {
          "type": "string",
          "description": "Unique identifier for the session"
