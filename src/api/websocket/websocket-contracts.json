{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-backend.utter.one/schemas/websocket-contracts.json",
  "title": "WebSocket Message Contracts",
  "description": "JSON Schema definitions for all WebSocket message types in the Nexus Backend API",
  "version": "1.0.0",
  "definitions": {
    "base-input-message": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "requestId": {
          "type": "string",
          "description": "Unique identifier for request correlation and tracking"
        },
        "type": {
          "type": "string",
          "description": "Message type discriminator for the union type system"
        }
      },
      "required": [
        "requestId",
        "type"
      ],
      "additionalProperties": false
    },
    "base-output-message": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "requestId": {
          "description": "Optional request ID for correlating responses with requests",
          "type": "string"
        },
        "type": {
          "type": "string",
          "description": "Message type discriminator for the union type system"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "session-input-message": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "requestId": {
          "type": "string",
          "description": "Unique identifier for request correlation and tracking"
        },
        "type": {
          "type": "string",
          "description": "Message type discriminator for the union type system"
        },
        "sessionId": {
          "type": "string",
          "description": "Unique identifier for the session"
        }
      },
      "required": [
        "requestId",
        "type",
        "sessionId"
      ],
      "additionalProperties": false
    },
    "session-output-message": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "requestId": {
          "description": "Optional request ID for correlating responses with requests",
          "type": "string"
        },
        "type": {
          "type": "string",
          "description": "Message type discriminator for the union type system"
        },
        "sessionId": {
          "type": "string",
          "description": "Unique identifier for the session"
        }
      },
      "required": [
        "type",
        "sessionId"
      ],
      "additionalProperties": false
    },
    "auth-request": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "requestId": {
          "type": "string",
          "description": "Unique identifier for request correlation and tracking"
        },
        "type": {
          "type": "string",
          "const": "auth",
          "description": "Message type for authentication"
        },
        "apiKey": {
          "type": "string",
          "description": "API key for authentication"
        }
      },
      "required": [
        "requestId",
        "type",
        "apiKey"
      ],
      "additionalProperties": false
    },
    "auth-response": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "requestId": {
          "description": "Optional request ID for correlating responses with requests",
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "auth",
          "description": "Message type for authentication response"
        },
        "success": {
          "type": "boolean",
          "description": "Whether authentication was successful"
        },
        "sessionId": {
          "description": "Unique identifier for the automatically created session",
          "type": "string"
        },
        "projectSettings": {
          "description": "Project settings available after authentication",
          "type": "object",
          "properties": {
            "projectId": {
              "type": "string",
              "description": "Unique identifier of the project"
            },
            "acceptVoice": {
              "type": "boolean",
              "description": "Whether conversations can accept voice input"
            },
            "generateVoice": {
              "type": "boolean",
              "description": "Whether conversations generate voice output"
            },
            "asrConfig": {
              "anyOf": [
                {
                  "description": "ASR configuration settings",
                  "type": "object",
                  "properties": {
                    "asrProviderId": {
                      "description": "ID of the ASR provider (e.g., \"azure-speech\", \"openai-whisper\")",
                      "type": "string"
                    },
                    "settings": {
                      "description": "ASR-specific settings including model, language preferences, etc.",
                      "type": "object",
                      "properties": {
                        "language": {
                          "description": "The language code for speech recognition (e.g., \"en-US\")",
                          "type": "string"
                        },
                        "dictionaryPhrases": {
                          "description": "The phrases to add to the speech recognition dictionary",
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "audioFormat": {
                          "description": "Audio input format for speech recognition (e.g., \"pcm_16000\")",
                          "type": "string",
                          "enum": [
                            "pcm_16000",
                            "pcm_22050",
                            "pcm_44100"
                          ]
                        }
                      },
                      "additionalProperties": false
                    },
                    "unintelligiblePlaceholder": {
                      "description": "Placeholder text to use when speech is unintelligible or cannot be transcribed",
                      "type": "string"
                    },
                    "voiceActivityDetection": {
                      "description": "Whether to enable voice activity detection to automatically start/stop recording based on speech presence",
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false
                },
                {
                  "type": "null"
                }
              ],
              "description": "ASR configuration settings with full ASR settings"
            }
          },
          "required": [
            "projectId",
            "acceptVoice",
            "generateVoice"
          ],
          "additionalProperties": false
        },
        "error": {
          "description": "Error message if authentication failed",
          "type": "string"
        }
      },
      "required": [
        "type",
        "success"
      ],
      "additionalProperties": false
    },
    "project-settings": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "projectId": {
          "type": "string",
          "description": "Unique identifier of the project"
        },
        "acceptVoice": {
          "type": "boolean",
          "description": "Whether conversations can accept voice input"
        },
        "generateVoice": {
          "type": "boolean",
          "description": "Whether conversations generate voice output"
        },
        "asrConfig": {
          "anyOf": [
            {
              "description": "ASR configuration settings",
              "type": "object",
              "properties": {
                "asrProviderId": {
                  "description": "ID of the ASR provider (e.g., \"azure-speech\", \"openai-whisper\")",
                  "type": "string"
                },
                "settings": {
                  "description": "ASR-specific settings including model, language preferences, etc.",
                  "type": "object",
                  "properties": {
                    "language": {
                      "description": "The language code for speech recognition (e.g., \"en-US\")",
                      "type": "string"
                    },
                    "dictionaryPhrases": {
                      "description": "The phrases to add to the speech recognition dictionary",
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "audioFormat": {
                      "description": "Audio input format for speech recognition (e.g., \"pcm_16000\")",
                      "type": "string",
                      "enum": [
                        "pcm_16000",
                        "pcm_22050",
                        "pcm_44100"
                      ]
                    }
                  },
                  "additionalProperties": false
                },
                "unintelligiblePlaceholder": {
                  "description": "Placeholder text to use when speech is unintelligible or cannot be transcribed",
                  "type": "string"
                },
                "voiceActivityDetection": {
                  "description": "Whether to enable voice activity detection to automatically start/stop recording based on speech presence",
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ],
          "description": "ASR configuration settings with full ASR settings"
        }
      },
      "required": [
        "projectId",
        "acceptVoice",
        "generateVoice"
      ],
      "additionalProperties": false
    },
    "start-conversation-request": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "requestId": {
          "type": "string",
          "description": "Unique identifier for request correlation and tracking"
        },
        "type": {
          "type": "string",
          "const": "start_conversation",
          "description": "Message type for starting a new conversation"
        },
        "sessionId": {
          "type": "string",
          "description": "Session ID in which to start the conversation"
        },
        "userId": {
          "type": "string",
          "description": "User ID initiating the conversation"
        },
        "personaId": {
          "description": "Optional persona ID for the conversation",
          "type": "string"
        },
        "stageId": {
          "type": "string",
          "description": "Stage ID to initiate the conversation at a specific stage"
        }
      },
      "required": [
        "requestId",
        "type",
        "sessionId",
        "userId",
        "stageId"
      ],
      "additionalProperties": false
    },
    "start-conversation-response": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "requestId": {
          "description": "Optional request ID for correlating responses with requests",
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "start_conversation",
          "description": "Message type for start conversation response"
        },
        "sessionId": {
          "type": "string",
          "description": "Unique identifier for the session"
        },
        "success": {
          "type": "boolean",
          "description": "Whether conversation was successfully started"
        },
        "conversationId": {
          "description": "Unique identifier for the created conversation",
          "type": "string"
        },
        "error": {
          "description": "Error message if conversation creation failed",
          "type": "string"
        }
      },
      "required": [
        "type",
        "sessionId",
        "success"
      ],
      "additionalProperties": false
    },
    "resume-conversation-request": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "requestId": {
          "type": "string",
          "description": "Unique identifier for request correlation and tracking"
