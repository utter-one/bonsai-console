    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vue/tsconfig": "^0.8.1",
    "swagger-typescript-api": "^13.2.16",    
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^5.4.21",
    "vue-tsc": "^3.1.4"
